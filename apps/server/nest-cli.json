{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "tsc",
    "typeCheck": true,
    "assets": [
      {
        "include": "notifications/locales/*.json",
        "outDir": "dist/src"
      }
    ]
  }
}
