// Verification tokens (email and phone OTP)
model VerificationToken {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      VerificationType
  token     String           @unique
  expiresAt DateTime
  consumed  Boolean          @default(false)
  payload   Json?
  createdAt DateTime         @default(now())

  @@map("verification_tokens")
}

enum VerificationType {
  EMAIL
  PHONE
  PASSWORD_RESET
  EMAIL_CHANGE
}

// In-app notifications for users
model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String?
  body      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

enum NotificationType {
  NEARBY_JOB
  JOB_MESSAGE
  APPLICATION_UPDATE
  SYSTEM
  LEGAL_ACTION
  WARNING
  ACTION_FORM
}

// Payments for Stripe integration
enum StripePaymentType {
  CHECKOUT_SESSION
  PAYMENT_INTENT
  SUBSCRIPTION
}

enum PaymentStatusDb {
  CREATED
  REQUIRES_ACTION
  SUCCEEDED
  CANCELED
  FAILED
}

model Payment {
  id                    String            @id @default(auto()) @map("_id") @db.ObjectId
  userId                String?           @db.ObjectId
  type                  StripePaymentType
  status                PaymentStatusDb   @default(CREATED)
  amount                Int?
  currency              String?
  stripePaymentIntentId String?
  stripeSessionId       String?
  stripeSubscriptionId  String?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  // Relation to Application (for job application payments) - one-to-many for additional payments
  applications Application[] @relation("ApplicationPayments")

  @@map("payments")
}

// Newsfeed posts (announcements, job updates)
model FeedPost {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  authorType   FeedAuthorType
  authorUserId String?        @db.ObjectId
  jobId        String?        @db.ObjectId
  title        String?
  body         String
  visibility   FeedVisibility @default(ALL)
  // Optional rich content and attachments
  attachments  String[]
  rich         Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("feed_posts")
}

enum FeedAuthorType {
  ADMIN
  EMPLOYER
  SYSTEM
}

enum FeedVisibility {
  ALL
  JOB_SEEKERS
  EMPLOYERS
}

// Reactions to feed posts (e.g., acknowledge)
model FeedReaction {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  postId    String           @db.ObjectId
  userId    String           @db.ObjectId
  type      FeedReactionType @default(ACK)
  createdAt DateTime         @default(now())

  @@unique([postId, userId, type])
  @@map("feed_reactions")
}

enum FeedReactionType {
  ACK
}

// Chat/conversation scaffolding
model Conversation {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  type        ConversationType
  title       String?
  jobId       String?          @db.ObjectId
  createdById String           @db.ObjectId
  locked      Boolean          @default(false)
  paused      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String          @db.ObjectId
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String          @db.ObjectId
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           ParticipantRole
  joinedAt       DateTime        @default(now())
  leftAt         DateTime?

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String           @db.ObjectId
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String?          @db.ObjectId
  sender         User?            @relation(name: "MessageSender", fields: [senderUserId], references: [id])
  senderRole     ParticipantRole?
  body           String
  payload        Json?
  createdAt      DateTime         @default(now())

  @@map("messages")
}

enum ConversationType {
  SUPPORT
  JOB
}

enum ParticipantRole {
  ADMIN
  EMPLOYER
  JOB_SEEKER
  BOT
}

// No-Show tracking for service providers
model NoShowRecord {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  serviceProviderId String       @db.ObjectId
  serviceProvider User           @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  applicationId   String         @db.ObjectId
  jobId           String         @db.ObjectId
  reportedBy      String         @db.ObjectId // Employer who reported
  offenseNumber   Int            // 1st, 2nd, 3rd...
  severity        NoShowSeverity // WARNING or PENALTY
  penaltyAmount   Int?           // In minor units (cents), null for warnings
  penaltyCurrency String?        // e.g. "EUR"
  resolved        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([serviceProviderId])
  @@index([applicationId])
  @@map("no_show_records")
}

enum NoShowSeverity {
  WARNING
  PENALTY
}

// Vehicle verification for service providers (transport, moving, delivery, etc.)
model Vehicle {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicleType            VehicleType
  otherTypeSpecification String?
  make                   String
  model                  String
  year                   Int
  color                  String?
  licensePlate           String
  capacity               String? // e.g. "2 tons", "Large van"

  // 4 vehicle photos + vehicle registration document
  photoFrontUrl     String?
  photoBackUrl      String?
  photoLeftUrl      String?
  photoRightUrl     String?
  vehicleLicenseUrl String?

  // Verification
  status     VehicleVerificationStatus @default(PENDING)
  adminNotes String?
  reviewedBy String?                   @db.ObjectId
  reviewedAt DateTime?

  // Document Analysis (Google Cloud Vision) — for vehicle license
  documentAnalysisScore Float?   // 0-100 trust score
  documentAnalysisFlags String[] // e.g. ["PLATE_MISMATCH", "EDITED_IMAGE"]
  documentAnalysisRaw   String?  // Full JSON from GCV analysis
  documentAnalyzedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("vehicles")
}

enum VehicleType {
  TRUCK
  VAN
  CAR
  MOTORCYCLE
  OTHER
}

enum VehicleVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}
