  "item": [
    {
      "name": "User Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let json;",
              "try { json = pm.response.json(); } catch (e) { json = {}; }",
              "if (json && json.accessToken) {",
              "  pm.environment.set('userAccessToken', json.accessToken);",
              "  pm.environment.set('accessToken', json.accessToken);",
              "}",
              "if (json && json.user && json.user.id) { pm.environment.set('userId', json.user.id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "User: GET /profiles/me",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{userAccessToken}}" } ],
        "url": { "raw": "{{baseUrl}}/profiles/me", "host": ["{{baseUrl}}"], "path": ["profiles","me"] }
      }
    },
