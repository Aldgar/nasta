{
  "info": {
    "name": "Background Checks",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end Background Check flow: user initiate/upload/status and admin review/assign/unassign/certificate"
  },
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/user/login", "host": ["{{baseUrl}}"], "path": ["auth","user","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login status 200/201', function(){ pm.expect(pm.response.code).to.be.within(200,201) });",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('accessToken');",
                  "pm.environment.set('userAuthToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Initiate Background Check",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAuthToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/initiate", "host": ["{{baseUrl}}"], "path": ["background-checks","initiate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consent\": { \n    \"accepted\": true,\n    \"version\": \"1\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200/201', function(){ pm.expect(pm.response.code).to.be.within(200,201) });",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('id');",
                  "pm.environment.set('checkId', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Upload Certificate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/{{checkId}}/upload-document", "host": ["{{baseUrl}}"], "path": ["background-checks","{{checkId}}","upload-document"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "certificate", "type": "file", "src": [] },
                { "key": "certificateNumber", "type": "text", "value": "" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function(){ pm.expect(pm.response.code).to.eql(200) });",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('checkId');",
                  "pm.environment.set('checkId', json.checkId);"
                ]
              }
            }
          ]
        },
        {
          "name": "My Background Check Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/my-status", "host": ["{{baseUrl}}"], "path": ["background-checks","my-status"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function(){ pm.expect(pm.response.code).to.eql(200) });",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('currentCheck');"
                ]
              }
            }
          ]
        },
        {
          "name": "Stream My Certificate",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/my/certificate/{{checkId}}", "host": ["{{baseUrl}}"], "path": ["background-checks","my","certificate","{{checkId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 or 404', function(){ pm.expect([200,404]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/admin/login", "host": ["{{baseUrl}}"], "path": ["auth","admin","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login status 200/201', function(){ pm.expect(pm.response.code).to.be.within(200,201) });",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('accessToken');",
                  "pm.environment.set('adminAuthToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Pending Reviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/admin/pending", "host": ["{{baseUrl}}"], "path": ["background-checks","admin","pending"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function(){ pm.expect(pm.response.code).to.eql(200) });",
                  "const arr = pm.response.json();",
                  "if (Array.isArray(arr) && arr.length) { pm.environment.set('checkId', arr[0].id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Scoped List (all)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/admin/reviews", "host": ["{{baseUrl}}"], "path": ["background-checks","admin","reviews"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function(){ pm.expect(pm.response.code).to.eql(200) });",
                  "const arr = pm.response.json();",
                  "if (Array.isArray(arr) && arr.length && !pm.environment.get('checkId')) { pm.environment.set('checkId', arr[0].id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Assign To Me",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/admin/{{checkId}}/assign", "host": ["{{baseUrl}}"], "path": ["background-checks","admin","{{checkId}}","assign"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function(){ pm.expect(pm.response.code).to.eql(200) });"
                ]
              }
            }
          ]
        },
        {
          "name": "Review: APPROVE (CLEAN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAuthToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/admin/{{checkId}}/review", "host": ["{{baseUrl}}"], "path": ["background-checks","admin","{{checkId}}","review"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"result\": \"CLEAN\",\n  \"hasCriminalRecord\": false,\n  \"canWorkWithChildren\": true,\n  \"canWorkWithElderly\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function(){ pm.expect(pm.response.code).to.eql(200) });",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('status');",
                  "pm.expect(['APPROVED','REJECTED']).to.include(json.status);"
                ]
              }
            }
          ]
        },
        {
          "name": "Stream Certificate (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/admin/{{checkId}}/certificate", "host": ["{{baseUrl}}"], "path": ["background-checks","admin","{{checkId}}","certificate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 or 404', function(){ pm.expect([200,404]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Unassign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAuthToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/background-checks/admin/{{checkId}}/unassign", "host": ["{{baseUrl}}"], "path": ["background-checks","admin","{{checkId}}","unassign"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function(){ pm.expect(pm.response.code).to.eql(200) });"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "userEmail", "value": "user@example.com" },
    { "key": "userPassword", "value": "password123" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "password123" },
    { "key": "userAuthToken", "value": "" },
    { "key": "adminAuthToken", "value": "" },
    { "key": "checkId", "value": "" }
  ]
}
