# Server environment (copy to .env and adjust values)

# Environment
# - development: local work
# - production: deployed API
NODE_ENV=development

# HTTP server
PORT=3001

# Database
DATABASE_URL="mongodb://localhost:27017/cumprido"

# JWT auth
JWT_SECRET="please-change-me"
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# NOTE: the server reads CORS_ORIGIN (not ORIGIN).
# - In development you may provide a comma-separated list of origins.
# - In production it should be a single origin URL.
# Examples:
#   development: CORS_ORIGIN="http://localhost:3000,http://localhost:3002"
#   production:  CORS_ORIGIN="https://cumprido.com"
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"

# Web client base URL (Next.js on port 3002 in dev)
CLIENT_BASE_URL="http://localhost:3002"

# Public base URL for the API server (used to generate clickable HTTPS links in emails)
# Example: https://api.cumprido.com
SERVER_PUBLIC_URL="http://localhost:3001"

# Optional: admin invite code used to gate admin creation flows
ADMIN_INVITE_CODE="please-change-me"

# Rate limiting (defaults shown)
THROTTLE_TTL=60
THROTTLE_LIMIT=20
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=5

# Stripe (required for payments)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Used to verify incoming Stripe webhooks
STRIPE_WEBHOOK_SECRET=""

# Platform fee configuration
# Percent is whole-number percentage (e.g. 20 means 20%)
PLATFORM_FEE_PERCENT=20
# Flat fee is in minor units (cents)
PLATFORM_FEE_FLAT=0

# Email (SMTP) - optional (if using SMTP)
SMTP_HOST=""
SMTP_PORT=
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Email (Resend) - optional
RESEND_API_KEY=""
RESEND_FROM="noreply@cumprido.com"

# Vonage (SMS) - optional
VONAGE_API_KEY=""
VONAGE_API_SECRET=""

# Numeric sender (E.164) fallback, if your market does not support alphanumeric sender IDs
VONAGE_FROM=""

# Branded sender name (market-dependent). Example: Cumprido
# If not supported in your destination country, carriers may replace it or it may fail.
SMS_FROM="Cumprido"

# Universal Links / App Links configuration (optional; required for deep link handoff from HTTPS)
APPLE_TEAM_ID=""
IOS_BUNDLE_ID="com.mohamedibrahim.cumprido"
ANDROID_PACKAGE_NAME="com.mohamedibrahim.cumprido"
ANDROID_SHA256_CERT_FINGERPRINT=""
