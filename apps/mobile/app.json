{
  "expo": {
    "name": "Cumprido",
    "slug": "cumprido",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "cumprido",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohamedibrahim.cumprido",
      "deploymentTarget": "16.0",
      "displayName": "Cumprido",
      "icon": "./assets/images/app-icon-ios.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to share it with your employer or track your service provider.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": ["applinks:cumprido.com"]
    },
    "android": {
      "package": "com.mohamedibrahim.cumprido",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cumprido.com",
              "pathPrefix": "/verify-email"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/CumpridoLogoLight.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#1A1F2E",
          "dark": {
            "backgroundColor": "#1A1F2E"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/CumpridoLogoDark.png",
          "color": "#6366f1",
          "sounds": []
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.mohamedibrahim.cumprido",
          "enableGooglePay": false
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "apiBaseURL": "https://api.cumprido.com",
      "router": {},
      "eas": {
        "projectId": "aa642c82-df86-4eb0-b7f0-2ae78e15b855"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
