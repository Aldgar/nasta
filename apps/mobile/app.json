{
  "expo": {
    "name": "Nasta",
    "slug": "nesta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "nasta",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohamedibrahim.nasta",
      "deploymentTarget": "16.0",
      "displayName": "Nasta",
      "icon": "./assets/images/app-icon-ios.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to share it with your employer or track your service provider.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:nasta.app"
      ]
    },
    "android": {
      "package": "com.mohamedibrahim.nasta",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCW8POXP0WZNwMCMWmoJv8zX7XcKtDxwVA"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nasta.app",
              "pathPrefix": "/verify-email"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/NastaLogoLight.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A1628",
          "dark": {
            "backgroundColor": "#0A1628"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "windowSoftInputMode": "adjustResize"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Nasta to access your photos for profile and document verification.",
          "cameraPermission": "Allow Nasta to use your camera for document capture and profile photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/NastaLogoDark.png",
          "color": "#C9963F",
          "sounds": []
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.mohamedibrahim.nasta",
          "enableGooglePay": false
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "apiBaseURL": "https://api.nasta.app",
      "router": {},
      "eas": {
        "projectId": "5ded41ee-3c4b-4612-8ac7-17c3aebc2356"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aa642c82-df86-4eb0-b7f0-2ae78e15b855"
    },
    "owner": "aldgar"
  }
}
